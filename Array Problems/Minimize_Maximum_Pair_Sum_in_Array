class Solution {
    public int minPairSum(int[] nums) {
        Arrays.sort(nums);
        int max = 0;
       // System.out.println(Arrays.toString(nums));
       int left = 0;
       int right = nums.length - 1;
       while(left <= right){
            max = Math.max(max , nums[left] + nums[right]);
            left++;
            right--;
       }
        return max;
        
    }
}
