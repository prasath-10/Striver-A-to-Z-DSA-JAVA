class Solution {
    public int maxScore(int[] cardPoints, int k) {
        int left=0;
        int sum=0;
        int max=0;
        int  rightindex=cardPoints.length-1;
        for(int i=0;i<k;i++)
        {
            sum=sum+cardPoints[i];
        }
        max=sum;
        for(int i=0;i<k;i++)
       {
          sum = sum - cardPoints[k - 1 - i] + cardPoints[cardPoints.length - 1 - i];
          max=Math.max(max,sum);
          
       }
        
       return max;
        
    }
}