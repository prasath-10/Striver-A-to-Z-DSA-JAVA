class Solution {
    public int countGoodSubstrings(String s) {
        HashSet<Character> set=new HashSet<>();
        int count=0;
        for(int i=0;i<s.length();i++)
        {
            set.clear();
            for(int j=i;j<s.length();j++)
            {
                set.add(s.charAt(j));
                int max=j-i+1;
                if(max == 3 && set.size() == 3){
                    count++;
                }
            }
        }
        return count;
        
    }
}